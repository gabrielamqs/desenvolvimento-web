{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bun: Run current TypeScript file",
      "type": "shell",
      "command": "bun",
      "args": [
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
